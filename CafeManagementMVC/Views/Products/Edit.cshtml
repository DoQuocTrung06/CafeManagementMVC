@model CafeManagementMVC.Models.Product

@{
    ViewData["Title"] = "Sửa thông tin món";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="d-flex justify-content-between align-items-center mb-3 mt-2">
    <h3 class="fw-bold text-primary">☕ CHỈNH SỬA THỰC ĐƠN</h3>
    <a asp-action="Index" class="btn btn-sm btn-outline-secondary fw-bold">
        🔙 Quay lại
    </a>
</div>

<div class="row justify-content-center">
    <div class="col-md-7 col-lg-5">
        <div class="card shadow-sm border-0 rounded-3">
            <div class="card-body p-4">
                <form asp-action="Edit" enctype="multipart/form-data">
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-2"></div>
                    <input type="hidden" asp-for="ProductId" />
                    <input type="hidden" asp-for="ImageUrl" />

                    <div class="form-group mb-3">
                        <label asp-for="ProductName" class="form-label fw-bold mb-1">Tên món</label>
                        <input asp-for="ProductName" class="form-control" placeholder="Nhập tên đồ uống..." />
                        <span asp-validation-for="ProductName" class="text-danger"></span>
                    </div>

                    <div class="form-group mb-3">
                        <label asp-for="CategoryId" class="form-label fw-bold mb-1">Thuộc danh mục</label>
                        <select asp-for="CategoryId" class="form-select" asp-items="ViewBag.CategoryId"></select>
                    </div>

                    <div class="form-group mb-3">
                        <label asp-for="Price" class="form-label fw-bold mb-1">Giá tiền gốc - Size S (VNĐ)</label>
                        <input asp-for="Price" id="BasePriceInput" type="number" class="form-control text-primary fw-bold" />
                        <span asp-validation-for="Price" class="text-danger"></span>
                        <small class="text-muted italic">Lưu ý: Nhập giá cho Size S. Hệ thống tự tính Size M (x1.2) và L (x1.5)</small>
                    </div>
                                     
                    <div class="form-group mb-3">
                        <label class="form-label fw-bold mb-1">Hình ảnh sản phẩm</label>
                        @if (!string.IsNullOrEmpty(Model.ImageUrl))
                        {
                            <div class="mb-2 text-center bg-light p-2 rounded-3 border">
                                <img src="@Model.ImageUrl" class="img-fluid" style="max-height: 90px; border-radius: 8px;" />
                            </div>
                        }
                        <input type="file" asp-for="ImageUpload" class="form-control form-control-sm" />
                    </div>

                    <div class="card p-2 mb-3 bg-light border-0">
                        <div class="form-check form-switch mb-1">
                            <input class="form-check-input" type="checkbox" asp-for="IsAvailable">
                                <label class="form-check-label fw-bold small">Còn bán</label>
                            </div>
                            <div class="form-check form-switch">
                                <input class="form-check-input" type="checkbox" asp-for="IsNew">
                                    <label class="form-check-label fw-bold text-danger small">Nhãn MỚI 🔥</label>
                                </div>
                            </div>

                            <button type="submit" class="btn btn-primary fw-bold w-100 py-2">💾 Cập nhật</button>
                        </form>
                    </div>
                </div>
            </div>
        </div>

        @section Scripts {
            @{
                await Html.RenderPartialAsync("_ValidationScriptsPartial");
            }
            <script>
                document.addEventListener("DOMContentLoaded", function () {
                    const priceInput = document.getElementById("BasePriceInput");
                    const previewBtns = document.querySelectorAll(".preview-size-btn");
                    const previewText = document.getElementById("PricePreview");

                    previewBtns.forEach(btn => {
                        btn.addEventListener("click", function () {
                           
                            previewBtns.forEach(b => b.classList.replace("btn-dark", "btn-outline-dark"));
                            this.classList.replace("btn-outline-dark", "btn-dark");

                            
                            const multiplier = parseFloat(this.dataset.multiplier);
                            const basePrice = parseFloat(priceInput.value) || 0;
                            const previewPrice = Math.round(basePrice * multiplier);
                    
                            previewText.innerText = "Giá khách thấy: " + previewPrice.toLocaleString('vi-VN') + " ₫";
                        });
                    });

                    
                    document.querySelector('.preview-size-btn[data-multiplier="1"]').click();
                });
            </script>
        }