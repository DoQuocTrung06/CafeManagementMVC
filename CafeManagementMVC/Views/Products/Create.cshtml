@model CafeManagementMVC.Models.Product

@{
    ViewData["Title"] = "Thêm món mới";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="d-flex justify-content-between align-items-center mb-3 mt-2">
    <h3 class="fw-bold text-primary">☕ THÊM MÓN MỚI</h3>
    <a asp-action="Index" class="btn btn-sm btn-outline-secondary fw-bold">
        🔙 Quay lại
    </a>
</div>

<div class="row justify-content-center">
    <div class="col-md-7 col-lg-5">

        <div class="card shadow-sm border-0 rounded-3">
            <div class="card-body p-4">

                <form asp-action="Create" enctype="multipart/form-data">

                    <div asp-validation-summary="ModelOnly" class="text-danger mb-2"></div>

                    <div class="form-group mb-3">
                        <label asp-for="ProductName" class="form-label fw-bold mb-1">Tên món</label>
                        <input asp-for="ProductName" class="form-control" placeholder="Ví dụ: Cà phê sữa đá" />
                        <span asp-validation-for="ProductName" class="text-danger small"></span>
                    </div>

                    <div class="form-group mb-3">
                        <label asp-for="CategoryId" class="form-label fw-bold mb-1">Danh mục</label>
                        <select asp-for="CategoryId" class="form-select" asp-items="ViewBag.CategoryId"></select>
                    </div>

                    <div class="form-group mb-3">
                        <label asp-for="Price" class="form-label fw-bold mb-1">Giá tiền (VNĐ)</label>
                        <div class="input-group">
                            <span class="input-group-text bg-light fw-bold">₫</span>
                            <input name="Price" id="Price" type="number" placeholder="0" class="form-control text-primary fw-bold" data-baseprice="0" style="transition: transform 0.15s ease;" />
                        </div>
                        <span asp-validation-for="Price" class="text-danger small"></span>
                    </div>

                                       <div class="form-group mb-3">
                        <label class="form-label fw-bold mb-1">Hình ảnh</label>
                        <input type="file" asp-for="ImageUpload" class="form-control form-control-sm" accept="image/*" />
                        <span asp-validation-for="ImageUpload" class="text-danger small"></span>
                    </div>

                    <div class="card p-2 mb-3 bg-light border-0">
                        <div class="form-check form-switch mb-1">
                            <input class="form-check-input" type="checkbox" asp-for="IsAvailable" checked style="cursor: pointer;">
                                <label class="form-check-label fw-bold small" asp-for="IsAvailable">Còn bán</label>
                            </div>

                            <div class="form-check form-switch">
                                <input class="form-check-input" type="checkbox" asp-for="IsNew" style="cursor: pointer;">
                                    <label class="form-check-label fw-bold text-danger small" asp-for="IsNew">Gắn nhãn MỚI (NEW) 🔥</label>
                                </div>
                            </div>

                            <div class="form-group mt-3">
                                <button type="submit" class="btn btn-primary fw-bold w-100 shadow-sm">
                                    💾 Lưu sản phẩm
                                </button>
                            </div>

                        </form>

                    </div>
                </div>

            </div>
        </div>

        @section Scripts {
            @{
                await Html.RenderPartialAsync("_ValidationScriptsPartial");
            }
    
            <script>
                                document.addEventListener("DOMContentLoaded", function () {
                    let priceInput = document.getElementById("Price");
                    let sizeInput = document.getElementById("Size");
                    let buttons = document.querySelectorAll(".size-btn");

                    
                    function setActive(btn) {
                        buttons.forEach(b => {
                            b.classList.remove("btn-dark", "text-white");
                            b.classList.add("btn-outline-dark");
                        });
                        btn.classList.remove("btn-outline-dark");
                        btn.classList.add("btn-dark", "text-white");
                    }

                    buttons.forEach(btn => {
                        btn.addEventListener("click", function () {
                            setActive(this);
                            
                            sizeInput.value = this.dataset.size;
            
                            
                            console.log("Đã chọn Size mặc định cho món là: " + sizeInput.value);
                        });
                    });
                });
            </script>
        }