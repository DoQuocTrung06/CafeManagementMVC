@model IEnumerable<CafeManagementMVC.Models.User>

@{
    ViewData["Title"] = "Quản lý nhân viên";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="d-flex justify-content-between align-items-center mb-4 mt-2">
    <h3 class="fw-bold text-primary"><i class="bi bi-people-fill"></i> QUẢN LÝ NHÂN VIÊN</h3>
    <a asp-action="Create" class="btn btn-primary fw-bold shadow-sm">
        <i class="bi bi-person-plus-fill"></i> Thêm nhân viên
    </a>
</div>

<div class="card shadow-sm border-0">
    <div class="card-body p-0">
        <table class="table table-hover align-middle mb-0">
            <thead class="table-light">
                <tr>
                    <th class="ps-3">Họ và Tên</th>
                    <th>Tên đăng nhập</th>
                    <th>Chức vụ</th>
                    <th>Trạng thái</th>
                    <th class="text-center">Thao tác</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td class="ps-3 fw-bold">@item.FullName</td>
                        <td>@item.Username</td>
                        <td>
                            @if (item.Role.RoleName.ToLower() == "admin")
                            {
                                <span class="badge bg-danger">Quản lý</span>
                            }
                            else
                            {
                                <span class="badge bg-info text-dark">Nhân viên</span>
                            }
                        </td>
                        <td>
                            @if (item.Status)
                            {
                                <span class="badge bg-success"><i class="bi bi-unlock-fill"></i> Đang hoạt động</span>
                            }
                            else
                            {
                                <span class="badge bg-secondary"><i class="bi bi-lock-fill"></i> Đã khóa</span>
                            }
                        </td>
                        <td class="text-center">
                            <a asp-action="Edit" asp-route-id="@item.UserId" class="btn btn-sm btn-outline-primary fw-bold">
                                ✏️ Sửa / Khóa
                            </a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>