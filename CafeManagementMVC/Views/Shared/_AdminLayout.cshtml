<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Admin Cafe</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
    <style>
        body { font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; background-color: #f8f9fa; }
        #wrapper { display: flex; align-items: stretch; }
        #sidebar { min-width: 250px; max-width: 250px; min-height: 100vh; background: #212529; color: #fff; transition: all 0.3s; }
        #sidebar .sidebar-header { padding: 20px; background: #1a1d20; text-align: center; }
        #sidebar ul p { color: #fff; padding: 10px; }
        #sidebar ul li a { padding: 15px 20px; font-size: 1.1em; display: block; color: #adb5bd; text-decoration: none; }
        #sidebar ul li a:hover { color: #fff; background: #343a40; }
        #sidebar ul li.active > a { color: #fff; background: #0d6efd; }
        #content { width: 100%; padding: 20px; }
        .navbar { background: #fff; box-shadow: 0 2px 5px rgba(0,0,0,0.1); }
    </style>
</head>
<body>
    <div id="wrapper">
        <nav id="sidebar">
            <div class="sidebar-header">
                <h4>Admin Cafe</h4>
            </div>
            <ul class="list-unstyled components">
                @{
                    var currentController = ViewContext.RouteData.Values["Controller"]?.ToString();
                }

                <li class="@(currentController == "Home" ? "active" : "")">
                    <a href="/Home/Index"><i class="bi bi-speedometer2 me-2"></i> Tổng quan</a>
                </li>
                <li class="@(currentController == "Categories" ? "active" : "")">
                    <a href="/Categories"><i class="bi bi-tag me-2"></i> Danh mục</a>
                </li>
                <li class="@(currentController == "Products" ? "active" : "")">
                    <a href="/Products"><i class="bi bi-cup-hot me-2"></i> Sản phẩm</a>
                </li>
                <li class="@(currentController == "CafeTables" ? "active" : "")">
                    <a href="/CafeTables"><i class="bi bi-table me-2"></i> Quản lý bàn</a>
                </li>
                <li class="@(currentController == "Orders" ? "active" : "")">
                    <a href="/Orders"><i class="bi bi-cart-check me-2"></i> Đơn hàng</a>
                </li>
                <hr>
                <li>
                    <a asp-controller="Account" asp-action="Logout" class="text-danger"><i class="bi bi-box-arrow-right me-2"></i> Đăng xuất</a>
                </li>
            </ul>
        </nav>

        <div id="content">
            <nav class="navbar navbar-expand-lg navbar-light">
                <div class="container-fluid">
                    <span class="navbar-text">
                        Xin chào, <strong>@User.Claims.FirstOrDefault(c => c.Type == "FullName")?.Value</strong>
                    </span>
                </div>
            </nav>

            <div class="container-fluid mt-4">
                @RenderBody()
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>