@model IEnumerable<CafeManagementMVC.Models.CartItem>

<style>
    /* CSS đồng bộ cho _CartPartial POS */
    .cart-card {
        border: none;
        border-radius: 12px; 
        overflow: hidden;
        box-shadow: 0 2px 8px rgba(0,0,0,0.04);
        background-color: #fff;
        transition: transform 0.2s ease;
    }
    .qty-btn-cart {
        width: 22px;
        height: 22px;
        border-radius: 50% !important;
        padding: 0;
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: bold;
        font-size: 0.7rem;
    }
</style>

@if (Model == null || !Model.Any())
{
    <div class="d-flex flex-column align-items-center justify-content-center text-center mt-4 px-3">
        <img src="https://cdn-icons-png.flaticon.com/512/11329/11329060.png" alt="Empty Cart" style="width: 120px; opacity: 0.7; margin-bottom: 20px;" />
        <h5 class="fw-bold text-dark mb-2">Giỏ hàng đang trống</h5>
        <p class="text-muted small">Hãy chọn món từ thực đơn bên trái để bắt đầu thanh toán.</p>
    </div>
}
else
{
    <div class="d-flex flex-column gap-3 mb-4">
        @foreach (var item in Model)
        {
            <div class="cart-card p-3 d-flex align-items-stretch">
                <div class="position-relative">
                    <img src="@(string.IsNullOrEmpty(item.ImageUrl) ? "https://cdn-icons-png.flaticon.com/512/3133/3133083.png" : item.ImageUrl)"
                         class="rounded-3 shadow-sm object-fit-cover"
                         style="width: 80px; height: 80px;" alt="@item.ProductName" />
                </div>

                <div class="ms-3 flex-grow-1 d-flex flex-column justify-content-between">
                    
                    <div class="d-flex justify-content-between align-items-start">
                        <h6 class="mb-0 fw-bold text-dark text-truncate pe-2" style="max-width: 160px; font-size: 1rem;">@item.ProductName</h6>
                        <button type="button" class="btn btn-link text-danger p-0 m-0 text-decoration-none" onclick="confirmDelete(@item.ProductId, '@item.Size')">
                            🗑️
                        </button>
                    </div>

                    <div class="d-flex align-items-center mt-1 gap-2">
                        <select class="form-select form-select-sm border-0 bg-light rounded-pill ps-2 pe-4 py-1 fw-bold text-dark shadow-none"
                                style="width: 90px; cursor: pointer; font-size: 0.85rem;" 
                                onchange="changeCartSize(@item.ProductId, '@item.Size', this.value)">
                            <option value="S" selected="@(item.Size == "S" ? "selected" : null)">Size S</option>
                            <option value="M" selected="@(item.Size == "M" ? "selected" : null)">Size M</option>
                            <option value="L" selected="@(item.Size == "L" ? "selected" : null)">Size L</option>
                        </select>
                        <span class="text-muted small fw-medium">| @item.Price.ToString("N0") ₫</span>
                    </div>

                    <div class="d-flex align-items-center justify-content-between mt-2">
                        <div class="d-flex align-items-center bg-light rounded-pill p-1">
                            <button type="button" class="btn btn-sm btn-light qty-btn-cart text-dark border-0 shadow-none" 
                                    onclick="updateCartItem(@item.ProductId, '@item.Size', -1)">
                                ➖
                            </button>

                            <span class="mx-2 fw-bold text-dark" style="min-width: 20px; text-align: center;">@item.Quantity</span>

                            <button type="button" class="btn btn-sm bg-white qty-btn-cart text-dark border-0 shadow-sm"
                                    onclick="updateCartItem(@item.ProductId, '@item.Size', 1)">
                                ➕
                            </button>
                        </div>

                        <div class="fw-bold text-danger" style="font-size: 1.05rem;">
                            @((item.Price * item.Quantity).ToString("N0")) ₫
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
}