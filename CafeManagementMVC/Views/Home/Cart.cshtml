@model IEnumerable<CafeManagementMVC.Models.CartItem>

@{
    ViewData["Title"] = "Giỏ Hàng";
    Layout = "~/Views/Shared/_CustomerLayout.cshtml";
    decimal grandTotal = Model?.Sum(x => x.TotalPrice) ?? 0;
}

<style>
    body {
        background-color: #f4f6f9;
    }
</style>

<div class="sticky-top bg-white shadow-sm py-3 px-3 mb-3 rounded-bottom-4">
    <div class="d-flex justify-content-between align-items-center">
        <a href="/Home/Menu?tableId=@ViewBag.TableId" class="text-decoration-none text-dark fs-4">
            🔙
        </a>
        <h4 class="mb-0 fw-bold text-primary">🛒 Giỏ Hàng</h4>
        <div class="badge bg-danger fs-6 px-3 py-2 rounded-pill shadow-sm">
            Bàn: @ViewBag.TableId
        </div>
    </div>
</div>

<div class="container-fluid px-3 pb-5">
    @if (Model == null || !Model.Any())
    {
        <div class="text-center mt-5">
            <h1 class="display-1 text-muted opacity-25 mb-3">🛒</h1>
            <h5 class="text-muted fw-bold">Giỏ hàng đang trống</h5>
            <p class="text-muted small">Bạn chưa chọn món nào cả. Hãy quay lại thực đơn nhé!</p>
            <a href="/Home/Menu?tableId=@ViewBag.TableId" class="btn btn-primary rounded-pill px-4 py-2 mt-2 fw-bold shadow-sm">
                🍽️ Xem Thực Đơn
            </a>
        </div>
    }
    else
    {
        <div class="card border-0 shadow-sm rounded-4 mb-4">
            <div class="card-body p-3">
                
                @foreach (var item in Model)
                {
                    <div class="card shadow-sm border-0 mb-3 rounded-4">
                        <div class="card-body p-3 d-flex align-items-center">
            
                            <img src="@(string.IsNullOrEmpty(item.ImageUrl) ? "https://cdn-icons-png.flaticon.com/512/3133/3133083.png" : item.ImageUrl)"
                                 class="rounded-3 shadow-sm object-fit-cover"
                                 style="width: 70px; height: 70px;" alt="@item.ProductName" />

                            <div class="ms-3 flex-grow-1">
                                <h6 class="mb-1 fw-bold text-dark text-truncate" style="max-width: 150px;">@item.ProductName</h6>
                                <div class="text-muted small mb-1">
                                    Size: <span class="badge bg-secondary">@item.Size</span> | @item.Price.ToString("N0") ₫
                                </div>
                
                                <div class="d-flex align-items-center mt-1">
                                    <form method="post" action="/Home/UpdateQuantity" class="m-0 p-0">
                                        <input type="hidden" name="productId" value="@item.ProductId" />
                                        <input type="hidden" name="size" value="@item.Size" />
                                        <input type="hidden" name="tableId" value="@ViewBag.TableId" />
                                        <input type="hidden" name="quantity" value="@(item.Quantity - 1)" />
                                        <button type="submit" class="btn btn-outline-secondary rounded-circle d-flex align-items-center justify-content-center"
                                                style="width: 26px; height: 26px; padding: 0;" @(item.Quantity <= 1 ? "disabled" : "")>
                                            <b>-</b>
                                        </button>
                                    </form>

                                    <span class="mx-2 fw-bold text-danger">@item.Quantity</span>

                                    <form method="post" action="/Home/UpdateQuantity" class="m-0 p-0">
                                        <input type="hidden" name="productId" value="@item.ProductId" />
                                        <input type="hidden" name="size" value="@item.Size" />
                                        <input type="hidden" name="tableId" value="@ViewBag.TableId" />
                                        <input type="hidden" name="quantity" value="@(item.Quantity + 1)" />
                                        <button type="submit" class="btn btn-outline-secondary rounded-circle d-flex align-items-center justify-content-center"
                                                style="width: 26px; height: 26px; padding: 0;">
                                            <b>+</b>
                                        </button>
                                    </form>
                                </div>
                            </div>

                            <div class="text-end ms-2">
                                <div class="fw-bold text-success mb-2" style="font-size: 0.95rem;">
                                    @((item.Price * item.Quantity).ToString("N0")) ₫
                                </div>
                
                                <form method="post" action="/Home/RemoveFromCart" class="m-0 p-0">
                                    <input type="hidden" name="productId" value="@item.ProductId" />
                                    <input type="hidden" name="size" value="@item.Size" />
                                    <input type="hidden" name="tableId" value="@ViewBag.TableId" />
                                    <button type="submit" class="btn btn-sm btn-danger rounded-3"
                                            onclick="return confirm('Bạn có chắc muốn bỏ món này khỏi giỏ không?');">
                                        🗑️
                                    </button>
                                </form>
                            </div>

                        </div>
                    </div>
                }

                <div class="d-flex justify-content-between align-items-center mt-2 pt-2">
                    <span class="fs-5 fw-bold text-secondary">Tổng thanh toán:</span>
                    <span class="fs-4 fw-bold text-danger">@grandTotal.ToString("N0") ₫</span>
                </div>
            </div>
        </div>

        <form method="post" action="/Home/PlaceOrder">
            <input type="hidden" name="tableId" value="@ViewBag.TableId" />
            <button type="submit" class="btn btn-success w-100 rounded-pill fw-bold py-3 fs-5 shadow">
                🚀 GỬI YÊU CẦU ĐẶT MÓN
            </button>
        </form>
    }
</div>