@model CafeManagementMVC.Models.Category

@{
    ViewData["Title"] = "Xóa Danh mục";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="container-fluid mt-2">
    <div class="row justify-content-center">
        <div class="col-md-8 col-lg-6">
            
            <div class="card shadow-sm border-0 rounded-3">
                <div class="card-header bg-danger text-white p-3 border-0" style="border-top-left-radius: 0.5rem; border-top-right-radius: 0.5rem;">
                    <h5 class="mb-0 fs-6">
                        <i class="bi bi-exclamation-triangle-fill me-2"></i> Xác nhận xóa danh mục
                    </h5>
                </div>
                
                <div class="card-body p-4">
                    <div class="alert alert-warning d-flex align-items-center mb-4 border-0 shadow-sm" role="alert">
                        <i class="bi bi-shield-exclamation flex-shrink-0 me-3 fs-3 text-warning"></i>
                        <div>
                            <h6 class="alert-heading fw-bold mb-1">Cảnh báo!</h6>
                            <span class="small">Bạn có chắc chắn muốn xóa danh mục này không? Hành động này <strong>không thể hoàn tác</strong>.</span>
                        </div>
                    </div>

                    <div class="mb-4">
                        <label class="text-muted small fw-bold text-uppercase mb-2">
                            @Html.DisplayNameFor(model => model.CategoryName)
                        </label>
                        <div class="p-3 bg-light rounded-3 border border-danger border-opacity-25">
                            <span class="fs-5 text-dark fw-semibold">
                                @Html.DisplayFor(model => model.CategoryName)
                            </span>
                        </div>
                    </div>

                    <form asp-action="Delete" class="d-flex justify-content-between align-items-center mt-4">
                        <input type="hidden" asp-for="CategoryId" />
                        
                        <a asp-action="Index" class="btn btn-secondary text-white px-4 shadow-sm">
                            <i class="bi bi-arrow-left me-1"></i> Quay lại
                        </a>
                        
                        <button type="submit" class="btn btn-danger px-4 shadow-sm">
                            <i class="bi bi-trash3-fill me-1"></i> Xác nhận xóa
                        </button>
                    </form>
                </div>
            </div>

        </div>
    </div>
</div>