@model CafeManagementMVC.Models.Category

@{
    ViewData["Title"] = "Thêm danh mục mới";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="container-fluid py-3">

    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h3 class="fw-bold text-dark mb-1">📁 Thêm danh mục</h3>
        </div>
    </div>

    <div class="row justify-content-center">
        <div class="col-lg-6 col-md-8">

            <div class="card border-0 shadow-lg rounded-4">
                <div class="card-body p-4">

                    <form asp-action="Create">

                        <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2"></div>

                        <div class="mb-3">
                            <label asp-for="CategoryName" class="form-label fw-semibold"></label>

                            <div class="input-group input-group-lg">
                                <span class="input-group-text bg-light">🏷️</span>
                                <input asp-for="CategoryName" class="form-control" />
                            </div>

                            <span asp-validation-for="CategoryName" class="text-danger small"></span>
                        </div>

                        <div class="d-flex gap-2 mt-4">
                            <button type="submit" class="btn btn-primary btn-lg w-100 shadow-sm">
                                💾 Lưu danh mục
                            </button>

                            <a asp-action="Index" class="btn btn-outline-secondary btn-lg w-100">
                                Hủy
                            </a>
                        </div>

                    </form>

                </div>
            </div>

        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}