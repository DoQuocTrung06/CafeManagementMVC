@model CafeManagementMVC.Models.Order
@{
    ViewData["Title"] = "Chi tiết đơn hàng";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="d-flex justify-content-between align-items-center mb-3 mt-2">
    <h3 class="fw-bold text-info">ℹ️ CHI TIẾT ĐƠN #@Model.OrderId</h3>
    <div>
        @* LOGIC IN BILL ĐÃ ĐƯỢC CHUẨN HÓA LẠI *@
        @if (Model.Status == "Đã thanh toán")
        {
            <a asp-action="PrintBill" asp-route-id="@Model.OrderId" target="_blank" class="btn btn-sm btn-success fw-bold me-2">
                <i class="bi bi-printer"></i> In Hóa Đơn
            </a>
        }
        else if (Model.Status == "Đã hủy")
        {
            @if (User.IsInRole("Admin"))
            {
                <a asp-action="PrintBill" asp-route-id="@Model.OrderId" target="_blank" class="btn btn-sm btn-warning fw-bold me-2" title="In lại để đối soát">
                    <i class="bi bi-printer"></i> In Hóa Đơn
                </a>
            }
        }
        @* Nếu là "Chờ xác nhận" thì sẽ KHÔNG HIỆN nút in bill nào cả *@

        <a asp-action="Index" class="btn btn-sm btn-outline-secondary fw-bold">🔙 Quay lại</a>
    </div>
</div>

<div class="row">
    <div class="col-md-4">
        <div class="card shadow-sm border-0 mb-3">
            <div class="card-body">
                <h5 class="fw-bold border-bottom pb-2">Thông tin chung</h5>
                <p><b>Bàn:</b> @(Model.CafeTable?.TableName ?? "Mang đi")</p>
                <p><b>Thời gian:</b> @Model.CreatedAt.ToString("HH:mm:ss dd/MM/yyyy")</p>
                <p>
                    <b>Trạng thái:</b>
                    <span class="badge
                        @(Model.Status == "Chờ xác nhận" ? "bg-warning text-dark" :
                            Model.Status == "Đã hủy" ? "bg-danger text-white" :
                            Model.Status == "Đã thanh toán" ? "bg-success text-white" :
                            "bg-info text-white")">
                        @Model.Status
                    </span>
                </p>
                <hr />
                <h5 class="text-danger fw-bold text-center">TỔNG: @Model.TotalAmount.ToString("N0") ₫</h5>
                
                <form asp-action="UpdateStatus" method="post" class="mt-4">
                    <input type="hidden" name="id" value="@Model.OrderId" />
                    <label class="fw-bold mb-2">Cập nhật trạng thái đơn:</label>

                    @* KIỂM TRA: Nếu đã hủy thì khóa hoàn toàn (quy tắc kế toán) *@
                    @if (Model.Status == "Đã hủy")
                    {
                        <div class="d-flex justify-content-center mb-3">
                            <span class="badge bg-danger fs-6 px-4 py-2">
                                ❌ Đã hủy
                            </span>
                        </div>
                        <div class="alert alert-danger text-center py-2">Đơn đã hủy - Không thể sửa</div>
                    }
                    @* Nếu đã thanh toán: Staff bị khóa, nhưng ADMIN vẫn được chỉnh (để Hủy đơn nếu cần) *@
                    else if (Model.Status == "Đã thanh toán" && !User.IsInRole("Admin"))
                    {
                        <div class="d-flex justify-content-center mb-3">
                            <span class="badge bg-success fs-6 px-4 py-2">
                                ✅ Đã thanh toán
                            </span>
                        </div>
                        <div class="alert alert-success text-center py-2">Đơn đã chốt - Chỉ Quản lý mới được sửa</div>
                    }
                    else
                    {
                       
                        <select name="status" class="form-select mb-3 fw-bold text-center">
                            
                            <option value="Chờ xác nhận" selected="@(Model.Status == "Chờ xác nhận")">
                                ⏳ Chờ xác nhận
                            </option>

                            <option value="Đã thanh toán" selected="@(Model.Status == "Đã thanh toán")" class="text-success">
                                ✅ Đã thanh toán
                            </option>

                            
                            @if (User.IsInRole("Admin"))
                            {
                                <option value="Đã hủy" selected="@(Model.Status == "Đã hủy")" class="text-danger">
                                    ❌ Đã hủy
                                </option>
                            }
                        </select>

                        <button type="submit" class="btn btn-primary w-100 fw-bold">
                            <i class="bi bi-save me-1"></i> CẬP NHẬT
                        </button>
                    }
                </form>
            </div>
        </div>
    </div>

    <div class="col-md-8">
        <div class="card shadow-sm border-0">
            <div class="card-body p-0">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th class="ps-3">Món ăn</th>
                            <th>Size</th>
                            <th>SL</th>
                            <th class="text-end pe-3">Thành tiền</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model.OrderDetails != null && Model.OrderDetails.Any())
                        {
                            foreach (var item in Model.OrderDetails)
                            {
                                <tr>
                                    <td class="ps-3">
                                        <div class="d-flex align-items-center">
                                            @if (item.Product != null)
                                            {
                                                <img src="@item.Product.ImageUrl" style="width:40px;height:40px;object-fit:cover" class="rounded me-2" alt="Ảnh món" />
                                                <b>@item.Product.ProductName</b>
                                            }
                                            else
                                            {
                                                <span class="text-muted">Món đã bị xóa</span>
                                            }
                                        </div>
                                    </td>
                                    <td><span class="badge border text-dark">@item.Size</span></td>
                                    <td>x @item.Quantity</td>
                                    <td class="text-end pe-3">@((item.Price * item.Quantity).ToString("N0")) ₫</td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="4" class="text-center py-4 text-muted">Đơn hàng không có món nào.</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>