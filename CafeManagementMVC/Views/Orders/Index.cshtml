@model IEnumerable<CafeManagementMVC.Models.Order>
@{
    ViewData["Title"] = "Quản lý đơn hàng";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="d-flex justify-content-between align-items-center mb-4 mt-2">
    <h3 class="fw-bold text-primary">📋 QUẢN LÝ ĐƠN HÀNG</h3>
    <form method="get" asp-action="Index" class="d-flex align-items-center">
        <label class="me-2 fw-bold text-nowrap">Xem ngày:</label>
        <input type="date" name="filterDate" class="form-control me-2" value="@ViewBag.SelectedDate" />
        <button type="submit" class="btn btn-primary px-4 fw-bold">Lọc</button>
    </form>
</div>

<div class="row mb-4 text-center">
    <div class="col-md-4">
        <div class="card bg-success text-white shadow-sm border-0 rounded-3">
            <div class="card-body py-4">
                <h6 class="fw-bold text-uppercase mb-2">Doanh thu (Đã thanh toán)</h6>
                <h3 class="mb-0 fw-bold">@ViewBag.TotalRevenue ₫</h3>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card bg-info text-dark shadow-sm border-0 rounded-3">
            <div class="card-body py-4">
                <h6 class="fw-bold text-uppercase mb-2">Đơn thành công</h6>
                <h3 class="mb-0 fw-bold">@ViewBag.SuccessOrders <span class="fs-5 fw-normal">đơn</span></h3>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card bg-danger text-white shadow-sm border-0 rounded-3">
            <div class="card-body py-4">
                <h6 class="fw-bold text-uppercase mb-2">Đơn đã hủy</h6>
                <h3 class="mb-0 fw-bold">@ViewBag.CanceledOrders <span class="fs-5 fw-normal">đơn</span></h3>
            </div>
        </div>
    </div>
</div>

<div class="card shadow-sm border-0 rounded-3">
    <div class="table-responsive">
        <table class="table table-hover align-middle mb-0">
            <thead class="table-light">
                <tr>
                    <th class="ps-4">Mã Đơn</th>
                    <th>Bàn</th>
                    <th>Thời gian đặt</th>
                    <th>Tổng tiền</th>
                    <th>Trạng thái</th>
                    <th class="text-center">Thao tác</th>
                </tr>
            </thead>
            <tbody>
                @if (!Model.Any())
                {
                    <tr>
                        <td colspan="6" class="text-center py-5 text-muted">
                            <i class="bi bi-inbox fs-2 d-block mb-2"></i>
                            Không có đơn hàng nào trong ngày này.
                        </td>
                    </tr>
                }
                else
                {
                    foreach (var item in Model)
                    {
                        <tr>
                            <td class="ps-4 fw-bold">#@item.OrderId</td>
                            <td><span class="badge bg-info text-dark">@(item.CafeTable?.TableName ?? "N/A")</span></td>
                            <td>@item.CreatedAt.ToString("HH:mm dd/MM")</td>
                            <td class="fw-bold text-danger">@item.TotalAmount.ToString("N0") ₫</td>
                            <td>
                                <span class="badge
                                    @(item.Status == "Chờ xác nhận" ? "bg-warning text-dark" :
                                                item.Status == "Đã hủy" ? "bg-danger text-white" :
                                                "bg-success text-white")">
                                    @item.Status
                                </span>
                            </td>
                            <td class="text-center">
                                <a asp-action="Details" asp-route-id="@item.OrderId" class="btn btn-sm btn-outline-primary fw-bold">
                                    <i class="bi bi-eye"></i> Xem & Duyệt
                                </a>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
</div>