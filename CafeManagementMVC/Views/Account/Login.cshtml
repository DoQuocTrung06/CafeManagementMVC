@model CafeManagementMVC.ViewModels.LoginViewModel
@{
    ViewData["Title"] = "Đăng nhập hệ thống";
    Layout = null; 
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Cafe Management</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <style>
            body { background-color: #f4f6f9; display: flex; align-items: center; justify-content: center; height: 100vh; }
            .login-card { border-radius: 15px; box-shadow: 0 4px 10px rgba(0,0,0,0.1); border: none; }
            .login-card-header { background-color: #0d6efd; color: white; border-radius: 15px 15px 0 0 !important; padding: 20px; text-align: center; }
    </style>
</head>
<body>
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-md-5">
                <div class="card login-card">
                    <div class="card-header login-card-header">
                        <h4>☕ HỆ THỐNG QUẢN LÝ QUÁN CAFE</h4>
                        <p class="mb-0">Vui lòng đăng nhập để tiếp tục</p>
                    </div>
                    <div class="card-body p-4">
                        @if (!ViewData.ModelState.IsValid)
                        {
                            <div class="alert alert-danger" role="alert">
                                @Html.ValidationSummary(false, "", new { @class = "mb-0" })
                            </div>
                        }

                        <form asp-action="Login" method="post">
                            <div class="mb-3">
                                <label asp-for="Username" class="form-label fw-bold">Tên đăng nhập</label>
                                <input asp-for="Username" class="form-control form-control-lg" placeholder="Nhập tài khoản..." />
                                <span asp-validation-for="Username" class="text-danger"></span>
                            </div>
                            <div class="mb-4">
                                <label asp-for="Password" class="form-label fw-bold">Mật khẩu</label>
                                <input asp-for="Password" class="form-control form-control-lg" placeholder="Nhập mật khẩu..." />
                                <span asp-validation-for="Password" class="text-danger"></span>
                            </div>
                            <button type="submit" class="btn btn-primary btn-lg w-100 fw-bold">ĐĂNG NHẬP</button>                
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>
</body>
</html>